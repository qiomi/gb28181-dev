# Set default behavior to LF for all text files
* text=auto eol=lf

# Explicitly declare source files as text with LF line endings
*.h text eol=lf
*.cpp text eol=lf
*.c text eol=lf
*.hpp text eol=lf

# Shell scripts should have LF
*.sh text eol=lf

# CMake files
CMakeLists.txt text eol=lf
*.cmake text eol=lf

# Markdown files
*.md text eol=lf

# YAML files
*.yml text eol=lf
*.yaml text eol=lf

# Configuration files
.clang-format text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# Binary files
*.so binary
*.a binary
*.o binary
*.exe binary
